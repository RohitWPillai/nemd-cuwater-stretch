# =====================================================================
#  NEMD Summer School 2026 - Day 1 stretch (Cu/water channel)
#  MEASUREMENT: shear viscosity
#
#  Shear the channel into steady Couette flow and measure two things:
#  the shear rate from the velocity profile vx(z), and the shear stress
#  from the water-only virial. The viscosity is eta = |p_xz| / (dvx/dz) -
#  the Day-1 viscosity measurement again, now in mPa*s against real water.
#
#  Run from this folder via the Cirrus wrapper:
#     ../submit.sh viscosity.in        (locally: lmp_serial -in viscosity.in)
#  then: python3 analyse_viscosity.py
#
#  This file sets its case parameters, then includes the shared setup with
#  `include ../shared_setup.lmp` (the Cu/water channel every stretch run shares).
# =====================================================================

# ---- case parameters (this measurement's settings; -var still overrides) ----
variable Tbot   index 300.0    # wall bath temperature (K); isothermal walls
variable Ttop   index 300.0
variable nequil index 10000    # equilibration steps (1 fs): the Couette profile develops here
variable nprod  index 20000    # production steps (multiple of 100): vx(z) and p_xz accumulate here
variable vwall  index 0.5      # anchor speed along x, each wall +/- (A/ps): the slip case's
                               # heating-screened value; the Push sheet raises it to 2.0
variable eps_sl index 0.0256   # O-Cu LJ epsilon (eV): 0.0256 wets fully (the slip case's knob)
variable binw   index 0.5      # profile bin width (A): vx(z) and the T(z) ingredients share it
variable delta  index 1.45     # depletion-layer thickness (A) read off the density case's
                               # smoothed rho(z): face-to-half-plateau distance, each wall

include ../shared_setup.lmp

# =====================================================================
#  MEASUREMENT: shear viscosity
#  The shared setup already drives the anchor layers at +/- vwall along x
#  and thermostats the moving baths in y,z only (see ../shared_setup.lmp).
#  Equilibrate into steady Couette flow, then time-average vx(z) and the
#  water shear stress.
# =====================================================================
run ${nequil}
reset_timestep 0

# wall faces (innermost wall-atom plane each side, read at production start):
# the stress volume below and the analyser's shear-rate fit use these
variable zfb equal bound(wbot,zmax)
variable zft equal bound(wtop,zmin)
print "Tbot ${Tbot}"          file   cuw_params.txt
print "Ttop ${Ttop}"          append cuw_params.txt
print "nequil ${nequil}"      append cuw_params.txt
print "nprod ${nprod}"        append cuw_params.txt
print "dt ${dt}"              append cuw_params.txt
print "binw ${binw}"          append cuw_params.txt
print "vwall ${vwall}"        append cuw_params.txt
print "eps_sl ${eps_sl}"      append cuw_params.txt
print "delta ${delta}"        append cuw_params.txt
print "zface_bot ${zfb}"      append cuw_params.txt
print "zface_top ${zft}"      append cuw_params.txt

# vx(z): O-atom mean velocity on ${binw} A bins, accumulated over the whole
# production window (the O atom carries 89% of the molecule's mass, so its
# mean velocity tracks the water's streaming velocity)
variable nsamp equal floor(v_nprod/10)
compute  cvx oxy chunk/atom bin/1d z lower ${binw} units box
fix      fvx oxy ave/chunk 10 ${nsamp} ${nprod} cvx vx file cuw_vx.profile

# per-bin kinetic ingredients for the analyser's water thermometer: it
# subtracts each bin's mass-weighted streaming velocity and counts only the
# 6 DOF SHAKE leaves per molecule, so its T(z) is thermal, not flow energy -
# this case's figure reads viscous heating off that peculiar T(z)
variable msq atom mass*(vx*vx+vy*vy+vz*vz)
variable mvx atom mass*vx
variable mvy atom mass*vy
variable mvz atom mass*vz
variable mm  atom mass
compute  zke water chunk/atom bin/1d z lower ${binw} units box
fix      fke water ave/chunk 10 ${nsamp} ${nprod} zke v_msq v_mvx v_mvy v_mvz v_mm &
         file cuw_ke.profile

# shear stress: water-only p_xz from the per-atom virial, ALL contributions
# (kinetic + pair + kspace + constraint; a pair-only sum misses part of the
# shear response). compute stress/atom is stress*volume per atom: summing the
# xz component over the water and dividing by the water volume gives p_xz
# without the stiff walls' virial. The volume is the wall-face gap minus the
# two depletion layers (no water occupies the first ${delta} A off each face);
# $(...) freezes it at production start so wall vibration cannot jitter it.
compute  sat  water stress/atom NULL
compute  spxz water reduce sum c_sat[5]
variable Vw   equal $(lx*ly*(v_zft-v_zfb-2.0*v_delta))
variable pxz  equal -c_spxz/v_Vw
fix      fpxz all ave/time 10 10 100 v_pxz file cuw_stress.dat

# fluid temperature trace over production (c_watT subtracts the SHAKE DOF
# but NOT the streaming motion; the analyser's profile thermometer does both)
fix      tout all ave/time 100 1 100 c_watT file cuw_viscosity_T.dat

# optional orientation trajectory for VMD/OVITO (production only; off by
# default, pass -var dump 1)
if "${dump} > 0" then &
  "dump dvmd all xyz 1000 cuw_traj.xyz" &
  "dump_modify dvmd element O H Cu Cu sort id"

run ${nprod}
print "Done. Analyse with:  python3 analyse_viscosity.py"
